{
  "schema_version": "kolm-product-invention-portfolio-1",
  "updated_at": "2026-06-17",
  "purpose": "Machine-readable invention backlog for the backend/product architecture. Each invention must improve tracked metrics, cover product journeys, name implementation surfaces, and smoke-test against the current product graph.",
  "metric_weights": {
    "quality": 0.22,
    "latency": 0.14,
    "cost": 0.14,
    "portability": 0.12,
    "proof": 0.16,
    "security": 0.1,
    "enterprise": 0.06,
    "dx": 0.04,
    "conversion": 0.02
  },
  "baseline": {
    "quality": 0.78,
    "latency": 0.62,
    "cost": 0.58,
    "portability": 0.66,
    "proof": 0.72,
    "security": 0.74,
    "enterprise": 0.6,
    "dx": 0.68,
    "conversion": 0.55
  },
  "implementation_rules": [
    "Every invention must cover at least one product journey, customization dimension, readiness requirement, and tracked metric.",
    "Every open readiness requirement must be covered by at least one invention until it is promoted to shipped or implemented.",
    "Every product journey must be covered by at least two inventions so no surface depends on a single architectural bet.",
    "Every metric class must have positive expected lift, but public claims still require real benchmark evidence before marketing.",
    "Synthetic lift is only prioritization evidence; production promotion needs the tests, reports, or external proof named by each readiness closeout."
  ],
