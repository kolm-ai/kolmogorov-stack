# Exclude local dev artifacts that don't belong in the Railway container.
# The /app/data volume on Railway is mounted separately at runtime.

# Local data + reports + tmp (gigabytes; never needed in prod container)
# Root-anchored so src/data/ (real source) is NOT excluded.
/data/
/reports/
/tmp/
/tmp-screenshots/
/screenshots/
/audit-shots/
/_audit/
/qa/
/md-links-test/
/archive/
/.cache/

# Model weights + ML artifacts (multi-GB binaries)
**/*.gguf
**/*.bin
**/*.safetensors
**/*.pth
**/*.pt
**/*.onnx
**/*.ckpt
**/*.h5

# Build inputs that get regenerated server-side
node_modules/
.git/

# The Next.js app (web/) is deployed to Vercel, not bundled into the API
# container. Exclude its build output + caches (node_modules already covered).
web/.next/
web/out/
web/.vercel/

# SDK source trees (Rust/C/Python build artifacts can be huge)
sdk/rust/target/
sdk/c/build/
sdk/python/dist/
sdk/python/build/
sdk/python/*.egg-info/
sdk/python/.venv/
**/__pycache__/

# Trinity + distill training scratch
trinity-*/
distill-*/

# Local dev configs
.env
.env.*
*.local
.DS_Store
Thumbs.db

# Test fixtures over 10 MB are not needed for runtime
**/*.traineddata

# Local Python virtualenvs
.venv/
venv/
env/

# Editor/IDE
.vscode/
.idea/
*.swp
*.swo

# Large simulation outputs (regenerated on demand)
sim-*.json

# GPU validation scratch + local engine state + screenshot artifacts (never in
# the prod container; also avoids the railway-up indexer choking on transient
# sqlite/lock files or odd filenames in these dev-only dirs).
/tmp-gpu/
/.kolm-state/
/audit/
/.shots-w912/
.shots-w912*.png
