{
  "name": "kolm-stack",
  "version": "0.2.6",
  "description": "kolm - the private AI compiler. Compile your task into a .kolm artifact, trained on your data, that runs on your hardware.",
  "private": true,
  "type": "module",
  "homepage": "https://kolm.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kolm-ai/kolmogorov-stack.git"
  },
  "bugs": {
    "url": "https://github.com/kolm-ai/kolmogorov-stack/issues"
  },
  "license": "Apache-2.0",
  "bin": {
    "kolm": "cli/kolm.js"
  },
  "scripts": {
    "start": "node scripts/build-sdk-version.js && node server.js",
    "dev": "node scripts/build-sdk-version.js && node --watch server.js",
    "seed": "node scripts/seed.js",
    "demo": "node scripts/demo.js",
    "build:sdk": "node scripts/build-sdk-version.js",
    "assets:fal": "node scripts/fal_generate_aurora.mjs",
    "build:product-graph": "node scripts/build-product-graph.cjs",
    "build:readiness-closeout": "node scripts/build-readiness-closeout.cjs",
    "build:file-ledger": "node scripts/build-codebase-file-ledger.cjs",
    "build:design-cascade-ledger": "node scripts/build-design-cascade-ledger.cjs",
    "build:wave-registry": "node scripts/build-wave-registry.cjs",
    "build:catalog-manifest": "node scripts/build-catalog-manifest.mjs",
    "build:product-media-proof": "node scripts/build-product-media-proof.cjs",
    "build:control-files": "npm run build:file-ledger && npm run build:design-cascade-ledger && npm run build:wave-registry && npm run build:catalog-manifest && npm run build:product-media-proof",
    "verify:file-ledger": "node scripts/build-codebase-file-ledger.cjs --check",
    "verify:design-cascade-ledger": "node scripts/build-design-cascade-ledger.cjs --check",
    "verify:wave-registry": "node scripts/build-wave-registry.cjs --check",
    "verify:catalog-manifest": "node scripts/build-catalog-manifest.mjs --check",
    "verify:product-media-proof": "node scripts/build-product-media-proof.cjs --check",
    "verify:control-files": "npm run verify:file-ledger && npm run verify:design-cascade-ledger && npm run verify:wave-registry && npm run verify:catalog-manifest && npm run verify:product-media-proof",
    "lint:refs": "node scripts/audit-static-refs.cjs && node scripts/audit-href.cjs --strict && node scripts/verify-product-surfaces.cjs",
    "verify:kernel": "node scripts/audit-product-kernel.cjs",
    "verify:surfaces": "node scripts/verify-product-surfaces.cjs",
    "local:surfaces": "node scripts/local-surface-smoke.cjs",
    "local:surfaces:deep": "node scripts/local-surface-smoke.cjs --deep",
    "prod:surfaces": "node scripts/prod-surface-smoke.cjs",
    "prod:surfaces:deep": "node scripts/prod-surface-smoke.cjs --deep --require-auth",
    "verify:compute": "node --test --test-concurrency=1 tests/wave551-compute-training-contract.test.js",
    "verify:sota": "node scripts/audit-sota-readiness.cjs && node scripts/build-readiness-closeout.cjs --check",
    "verify:claims-scope": "node scripts/audit-claim-scope.cjs",
    "verify:brand": "node --test --test-concurrency=1 tests/wave431-source-mojibake-clean.test.js tests/wave594-kolm-brand-contract.test.js",
    "verify:kscore-calibration": "node --test --test-concurrency=1 tests/wave145-kscore-t-axis.test.js tests/wave506-kscore-leaderboard-submission-honesty.test.js tests/wave587-kscore-calibration-contract.test.js",
    "verify:platform": "node scripts/cloud-readiness.mjs --summary --json",
    "verify:codegraph": "node scripts/build-codegraph.mjs --check --json",
    "verify:journeys": "node scripts/audit-product-journeys.mjs --json",
    "verify:invention-spec": "node scripts/simulate-invention-implementation-spec.cjs --summary && node --test --test-concurrency=1 tests/wave593-invention-implementation-spec.test.js",
    "verify:frontier-map": "node scripts/simulate-product-frontier-map.cjs --summary && node --test --test-concurrency=1 tests/wave595-product-frontier-map.test.js",
    "verify:math-frontier": "node scripts/simulate-product-math-frontier.cjs --summary && node --test --test-concurrency=1 tests/wave596-product-math-frontier.test.js",
    "verify:invention-buildbook": "node scripts/simulate-product-invention-buildbook.cjs --summary && node --test --test-concurrency=1 tests/wave598-product-invention-buildbook.test.js",
    "verify:research-atlas": "node scripts/simulate-product-research-atlas.cjs --summary && node --test --test-concurrency=1 tests/wave600-product-research-atlas.test.js",
    "verify:frontier-lab": "node scripts/simulate-product-frontier-lab.cjs --summary && node --test --test-concurrency=1 tests/wave601-product-frontier-lab.test.js tests/wave602-product-frontier-lab-api.test.js",
    "verify:frontier-contracts": "node scripts/simulate-product-frontier-implementation-contracts.cjs --summary && node --test --test-concurrency=1 tests/wave603-product-frontier-implementation-contracts.test.js tests/wave604-product-frontier-contracts-api.test.js",
    "verify:operator-kernels": "node scripts/simulate-product-frontier-operator-kernels.cjs --summary && node --test --test-concurrency=1 tests/wave605-product-frontier-operator-kernels.test.js tests/wave606-product-frontier-operator-kernels-api.test.js",
    "verify:build-strategy": "node scripts/build-strategy-brain.mjs --catalog && node --test --test-concurrency=1 tests/wave597-build-strategy-brain.test.js",
    "verify:readiness-workorders": "node scripts/simulate-readiness-gate-workorders.cjs --summary && node --test --test-concurrency=1 tests/wave599-readiness-gate-workorders.test.js",
    "verify:inventions": "node scripts/simulate-invention-portfolio.cjs --summary && npm run verify:invention-spec && npm run verify:frontier-map && npm run verify:math-frontier && npm run verify:invention-buildbook && npm run verify:research-atlas && npm run verify:frontier-lab && npm run verify:frontier-contracts && npm run verify:operator-kernels",
    "verify:redaction-benchmark": "node scripts/bench-redaction-fixtures.mjs --min-f1 0.95 --min-recall 0.95 --max-fp 0 && node --test --test-concurrency=1 tests/wave581-redaction-benchmark.test.js tests/wave586-redaction-public-benchmark-contract.test.js",
    "verify:quality-calibration": "node scripts/bench-quality-calibration.mjs --min-agreement 0.98 --max-brier 0.18 --max-false-accept 0 && node --test --test-concurrency=1 tests/wave588-quality-calibration-contract.test.js",
    "verify:benchmark-evidence": "node scripts/benchmark-evidence.mjs --summary --require-local-contract",
    "verify:governance-packets": "node scripts/format-governance-packet.mjs --summary --require-local-contract && node scripts/runtime-adoption-packets.mjs --summary --require-local-contract",
    "verify:compliance-packet": "node scripts/compliance-certification-packet.mjs --summary --require-local-contract && node --test --test-concurrency=1 tests/wave592-compliance-certification-packet.test.js",
    "verify:quant-oracle": "node scripts/quantization-oracle.mjs --task extraction --device rtx-4090-24gb --params-b 7 --context 8192 --calibration-rows 256",
    "verify:cloud-broker": "node scripts/cloud-compute-broker.mjs --simulate runpod-r2 --workload train --params-b 7 --rows 2000 --no-local-gpu --summary --require-ready",
    "verify:distill-strategy": "node scripts/distill-strategy.mjs --simulate anthropic --task generation --real-pairs 1500 --holdout-pairs 300 --summary --require-ready",
    "verify:federated": "node --test --test-concurrency=1 tests/wave409u-federated-foundation.test.js tests/wave585-federated-robust-aggregation.test.js tests/wave538-federated-route-docs.test.js",
    "verify:package-release": "node scripts/package-release-readiness.mjs --summary --require-local-contract && node scripts/package-release-readiness.mjs --smoke-installers --summary && node scripts/package-release-readiness.mjs --run-local-checks --summary && npm --prefix packages/attestation test && node --test --test-concurrency=1 tests/wave591-package-local-build-contract.test.js",
    "verify:depth": "node scripts/audit-product-kernel.cjs --json && node scripts/audit-product-journeys.mjs --json && node scripts/cloud-readiness.mjs --summary --json && node scripts/build-codegraph.mjs --check --json && node scripts/simulate-invention-portfolio.cjs --summary && npm run verify:invention-spec && npm run verify:frontier-map && npm run verify:math-frontier && npm run verify:invention-buildbook && npm run verify:research-atlas && npm run verify:frontier-lab && npm run verify:frontier-contracts && npm run verify:operator-kernels && npm run verify:build-strategy && node scripts/bench-redaction-fixtures.mjs --min-f1 0.95 --min-recall 0.95 --max-fp 0 && node --test --test-concurrency=1 tests/wave581-redaction-benchmark.test.js tests/wave586-redaction-public-benchmark-contract.test.js && npm run verify:kscore-calibration && npm run verify:quality-calibration && npm run verify:benchmark-evidence && npm run verify:governance-packets && npm run verify:compliance-packet && node scripts/quantization-oracle.mjs --task extraction --device rtx-4090-24gb --params-b 7 --context 8192 --calibration-rows 256 && node scripts/cloud-compute-broker.mjs --simulate runpod-r2 --workload train --params-b 7 --rows 2000 --no-local-gpu --summary --require-ready && node scripts/distill-strategy.mjs --simulate anthropic --task generation --real-pairs 1500 --holdout-pairs 300 --summary --require-ready && node --test --test-concurrency=1 tests/wave409u-federated-foundation.test.js tests/wave585-federated-robust-aggregation.test.js tests/wave538-federated-route-docs.test.js && npm run verify:package-release && node scripts/audit-sota-readiness.cjs && node scripts/build-readiness-closeout.cjs --check && npm run verify:readiness-workorders && node scripts/audit-claim-scope.cjs && npm run verify:brand",
    "qa:shots": "node scripts/qa-screenshots.mjs",
    "qa:shots:quick": "node scripts/qa-screenshots.mjs --quick",
    "qa:shots:local": "node scripts/qa-screenshots.mjs --base http://localhost:8787",
    "ui:audit": "node scripts/ui-surface-audit.cjs",
    "ui:audit:critical": "node scripts/ui-surface-audit.cjs",
    "ui:audit:all": "node scripts/ui-surface-audit.cjs --all",
    "ui:audit:all:themes": "node scripts/ui-surface-audit.cjs --all --themes=dark,light",
    "test": "node --test --test-concurrency=1 tests/*.test.js",
    "test:parallel": "node --test tests/*.test.js",
    "release:verify": "node scripts/release-verify.cjs",
    "lint": "eslint src cli scripts tests workers",
    "lint:fix": "eslint --fix src cli scripts tests workers"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.98.0",
    "@iarna/toml": "2.2.5",
    "adm-zip": "0.5.17",
    "apache-arrow": "21.1.0",
    "archiver": "7.0.1",
    "compression": "1.8.1",
    "cookie-parser": "1.4.7",
    "dotenv": "16.6.1",
    "express": "4.22.1",
    "express-rate-limit": "7.5.1",
    "helmet": "8.1.0",
    "parquetjs-lite": "0.8.7",
    "pdfkit": "0.18.0",
    "pg": "8.13.1",
    "ssh2": "1.16.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "cli/",
    "src/",
    "services/",
    "sdk/",
    "!sdk/**/node_modules",
    "!sdk/**/__pycache__",
    "!sdk/**/*.pyc",
    "!sdk/rust/target",
    "scripts/build-sdk-version.js",
    "server.js",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "eslint": "9.39.4",
    "globals": "17.6.0",
    "playwright": "1.60.0"
  }
}
