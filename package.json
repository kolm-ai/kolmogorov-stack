{
  "name": "kolmogorov-stack",
  "version": "0.1.0",
  "description": "kolm — the compiler cache for intelligence. Compile any AI task into a portable, signed .kolm artifact that runs anywhere.",
  "private": true,
  "type": "module",
  "main": "server.js",
  "bin": {
    "kolm": "cli/kolm.js"
  },
  "scripts": {
    "start": "node scripts/build-sdk-version.js && node server.js",
    "dev": "node scripts/build-sdk-version.js && node --watch server.js",
    "seed": "node scripts/seed.js",
    "demo": "node scripts/demo.js",
    "build:sdk": "node scripts/build-sdk-version.js",
    "test": "node --test tests/e2e.test.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "adm-zip": "^0.5.17",
    "archiver": "^7.0.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
