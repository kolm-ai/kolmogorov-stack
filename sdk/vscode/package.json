{
  "name": "kolm-vscode",
  "displayName": "Kolm: signed AI artifacts",
  "description": "Compile, inspect, verify, and run .kolm artifacts without leaving your editor. Detects LLM calls and offers to swap them for a signed, deterministic kolm artifact.",
  "version": "0.3.0",
  "publisher": "kolm",
  "license": "Apache-2.0",
  "homepage": "https://kolm.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kolm-ai/kolm-stack.git",
    "directory": "sdk/vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["AI", "Other", "Programming Languages"],
  "keywords": [
    "kolm",
    "kolm-stack",
    "llm",
    "claude",
    "openai",
    "anthropic",
    "artifact",
    "compile",
    "verify",
    "k-score",
    "receipt",
    ".kolm"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:python",
    "onCommand:kolm.inspect",
    "onCommand:kolm.verify",
    "onCommand:kolm.run",
    "onCommand:kolm.compile",
    "onCommand:kolm.search",
    "onCommand:kolm.openConsole",
    "onCommand:kolm.replaceLLMCall",
    "onCommand:kolm.distillCodingAssistant",
    "onCommand:kolm.viewCaptures",
    "onCommand:kolm.viewCostSavings"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      { "command": "kolm.inspect",         "title": "Kolm: Inspect this .kolm artifact" },
      { "command": "kolm.verify",          "title": "Kolm: Verify this .kolm artifact" },
      { "command": "kolm.run",             "title": "Kolm: Run a .kolm artifact with an input" },
      { "command": "kolm.compile",         "title": "Kolm: Compile a new artifact from a spec" },
      { "command": "kolm.search",          "title": "Kolm: Search the public registry" },
      { "command": "kolm.replaceLLMCall",  "title": "Kolm: Replace this LLM call with a kolm artifact" },
      { "command": "kolm.openConsole",     "title": "Kolm: Open the dashboard" },
      { "command": "kolm.distillCodingAssistant", "title": "Kolm: Distill my coding assistant" },
      { "command": "kolm.viewCaptures",    "title": "Kolm: View recent captures" },
      { "command": "kolm.viewCostSavings", "title": "Kolm: View today's cost savings" }
    ],
    "menus": {
      "editor/context": [
        { "command": "kolm.replaceLLMCall", "group": "1_modification", "when": "editorHasSelection" }
      ],
      "explorer/context": [
        { "command": "kolm.inspect", "when": "resourceExtname == .kolm", "group": "navigation" },
        { "command": "kolm.verify",  "when": "resourceExtname == .kolm", "group": "navigation" },
        { "command": "kolm.run",     "when": "resourceExtname == .kolm", "group": "navigation" }
      ]
    },
    "configuration": {
      "title": "Kolm",
      "properties": {
        "kolm.apiKey": {
          "type": "string",
          "default": "",
          "description": "Kolm API key (ks_...). Get one at https://kolm.ai/signup. Falls back to KOLM_API_KEY env var."
        },
        "kolm.baseUrl": {
          "type": "string",
          "default": "https://kolm.ai",
          "description": "Kolm API base URL. Default points at the hosted service."
        },
        "kolm.suggestReplacements": {
          "type": "boolean",
          "default": true,
          "description": "Show inline CodeLens suggestions on detected LLM calls."
        },
        "kolm.showRestEquivalent": {
          "type": "boolean",
          "default": true,
          "description": "After running a command, log the equivalent REST call so the editor doubles as an API tutorial."
        },
        "kolm.namespace": {
          "type": "string",
          "default": "vscode-codegen",
          "description": "Namespace used by the W731 capture watcher when POSTing to /v1/capture/log."
        },
        "kolm.costPerCall": {
          "type": "number",
          "default": 0.003,
          "description": "Estimated teacher cost per call in USD (default $0.003 ~ Claude Sonnet 1k tokens). Drives the W731 cost-savings status bar."
        },
        "kolm.captureWatcher.enabled": {
          "type": "boolean",
          "default": true,
          "description": "W731-1: watch document changes for Copilot/Claude Code completions and POST to /v1/capture/log."
        },
        "kolm.captureWatcher.throttleMs": {
          "type": "number",
          "default": 5000,
          "description": "Minimum interval between captures per file (W731-1)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "echo 'no-op'",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0"
  }
}
