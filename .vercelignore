# server.js MUST stay uploaded — Vercel framework auto-detect searches for
# server.{js,cjs,mjs,ts,cts,mts} and fails the build if none is found.
# Auto-bundling of server.js as a fallback function is prevented via
# `"framework": null` in vercel.json (only api/* are functions).
#
# Backend-only configs not needed by Vercel functions
Dockerfile
railway.toml
ecosystem.config.cjs

# Heavy dirs that don't need to ship to Vercel runtime
tests/
bench/
workers/
apps/
packages/
_audit/
audit-shots/
archive/
backups/
data/
build/
bin/

# Plans, audits, internal docs (not for serverless bundle)
KOLM_*.md
FINAL_*.md
INTERNAL_*.md
STRATEGY.md
DEMO.md
AGENT_GUIDE.md
CONTRIBUTING.md

# Scratch
all_hrefs.txt
