{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "kolm.ai runtime reference dashboard (W823 upgrade). 6 panels: K-Score over time, K-Score drift gauge, p95 latency by artifact, fallback rate (stacked area), token confidence distribution, routing-decision breakdown. Replace PROMETHEUS_DS_UID and namespace label values before saving.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_DS_UID"
      },
      "description": "Calibrated K-Score point estimate over time per namespace. Lower values indicate the artifact is drifting away from its calibration baseline.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisLabel": "K-Score",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "never",
            "spanNulls": false
          },
          "min": 0,
          "max": 1,
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PROMETHEUS_DS_UID"
          },
          "editorMode": "code",
          "expr": "kolm_kscore_point",
          "legendFormat": "{{namespace}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "K-Score over time",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_DS_UID"
      },
      "description": "W823 K-Score drift gauge. Surfaces kolm.kscore.drift (signed delta vs 24h baseline). Red beyond +/-0.05 — matches the W823-3 alert threshold so the dashboard and alerts agree on what 'drift' means.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "min": -0.2,
          "max": 0.2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": -0.05
              },
              {
                "color": "green",
                "value": -0.02
              },
              {
                "color": "yellow",
                "value": 0.02
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PROMETHEUS_DS_UID"
          },
          "editorMode": "code",
          "expr": "kolm_kscore_drift",
          "legendFormat": "{{namespace}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "K-Score drift gauge",
      "type": "gauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_DS_UID"
      },
      "description": "W823 p95 inference latency per artifact_id (kolm.artifact.id). Regressions above the 24h baseline of >25% match the W823-3 latency-regression alert.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisLabel": "ms",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "never",
            "spanNulls": false
          },
          "min": 0,
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PROMETHEUS_DS_UID"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum(rate(kolm_inference_latency_ms_bucket[5m])) by (le, artifact_id))",
          "legendFormat": "{{artifact_id}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "p95 latency by artifact",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_DS_UID"
      },
      "description": "W823 fallback rate stacked area — fallback-to-teacher decisions split by routing.decision (student vs teacher vs mixed). Spike above 15% in 15min trips the W823-3 fallback alert.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisLabel": "ratio",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 70,
            "lineWidth": 1,
            "pointSize": 4,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "normal"
            }
          },
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 0.15
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 4,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PROMETHEUS_DS_UID"
          },
          "editorMode": "code",
          "expr": "sum(rate(kolm_routing_decision_total[5m])) by (routing_decision)",
          "legendFormat": "{{routing_decision}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Fallback rate (stacked area)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_DS_UID"
      },
      "description": "W823 token confidence distribution — histogram of kolm.token.confidence_p50 (entropy in nats). Lower entropy = higher confidence; the long-right tail captures degenerate prompts the local model finds uncertain.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "axisLabel": "count",
            "axisPlacement": "auto",
            "fillOpacity": 80,
            "lineWidth": 1,
            "scaleDistribution": {
              "type": "linear"
            }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 5,
      "options": {
        "bucketSize": 0.05,
        "combine": false,
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PROMETHEUS_DS_UID"
          },
          "editorMode": "code",
          "expr": "sum(rate(kolm_token_confidence_p50_bucket[5m])) by (le)",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Token confidence distribution",
      "type": "histogram"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_DS_UID"
      },
      "description": "W823 routing-decision breakdown — pie split across student / teacher / mixed using the W823-1 kolm.routing.decision attribute. Sum over the dashboard time range.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            }
          },
          "mappings": [],
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "id": 6,
      "options": {
        "displayLabels": [
          "name",
          "percent"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": [
            "value",
            "percent"
          ]
        },
        "pieType": "pie",
        "reduceOptions": {
          "calcs": [
            "sum"
          ],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PROMETHEUS_DS_UID"
          },
          "editorMode": "code",
          "expr": "sum(increase(kolm_routing_decision_total[$__range])) by (routing_decision)",
          "legendFormat": "{{routing_decision}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Routing-decision breakdown",
      "type": "piechart"
    }
  ],
  "refresh": "30s",
