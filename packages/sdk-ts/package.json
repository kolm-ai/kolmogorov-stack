{
  "name": "kolm",
  "version": "0.2.6",
  "description": "One-line embed for .kolm artifacts. TypeScript / JavaScript SDK.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node ../../scripts/verify-sdk-dist.mjs sdk-ts",
    "test": "node --test test"
  },
  "keywords": [
    "kolm",
    "ai-compiler",
    "llm",
    "lora",
    "edge",
    "inference",
    "verifiable",
    "receipt"
  ],
  "author": "Kolm",
  "homepage": "https://kolm.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/kolm-ai/kolm",
    "directory": "packages/sdk-ts"
  },
  "bugs": {
    "url": "https://github.com/kolm-ai/kolm/issues"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
